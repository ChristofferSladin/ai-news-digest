# Secrets for the ingest console app + Cloudflare tooling. NEVER commit real values.
#
# Local .NET dev: either `export` these in your shell before `dotnet run`, or (preferred)
# use `dotnet user-secrets` — see the README. In CI they are GitHub Actions secrets.
# `--dry-run` needs none of these.

# Google Gemini API key (free tier, AI Studio) — used by the summarizer.
GEMINI_API_KEY=

# Cloudflare account id.
CF_ACCOUNT_ID=

# Cloudflare D1 database id (output of `wrangler d1 create solarm2m_digest`).
D1_DATABASE_ID=

# Cloudflare API token scoped to D1:Edit — used by the .NET writer (REST) and Wrangler.
CF_API_TOKEN=
